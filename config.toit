// Default configuration for the Stress Tool.
// These values are used if no command-line arguments are provided.

/** Number of concurrent tasks to spawn. */
DEFAULT_TASKS ::= 5

/** 
The default intensity level. 
0.20 = MIN, 0.65 = MEDIUM, 0.90 = HIGH, 1.00 = MAX 
*/
DEFAULT_INTENSITY ::= 0.65

/** Default duration in seconds. Set to null for infinite. */
DEFAULT_DURATION_SECONDS ::= 30
